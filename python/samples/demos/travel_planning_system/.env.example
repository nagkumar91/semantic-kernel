# APPINSIGHTS_CONNECTION_STRING="..."
# SEMANTICKERNEL_EXPERIMENTAL_GENAI_ENABLE_OTEL_DIAGNOSTICS=true
# SEMANTICKERNEL_EXPERIMENTAL_GENAI_ENABLE_OTEL_DIAGNOSTICS_SENSITIVE=true
# AZURE_OPENAI_CHAT_DEPLOYMENT_NAME="gpt-4o-mini"
# AZURE_OPENAI_ENDPOINT="..."


# Travel Planning System Environment Configuration
# =============================================================================
# Azure OpenAI Configuration
# =============================================================================
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_API_VERSION="2024-12-01-preview"
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME="gpt-4.1-mini"

# =============================================================================
# Observability / Application Insights Configuration
# =============================================================================
# Comment out or remove for development without Azure Monitor
APPLICATIONINSIGHTS_CONNECTION_STRING=""

# =============================================================================
# Jaeger/OTLP Configuration (for local development)
# =============================================================================
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT="http://localhost:4318/v1/traces"
OTEL_SERVICE_NAME="SemanticKernel-TravelPlanning"

# =============================================================================
# Semantic Kernel Observability Settings
# =============================================================================
SEMANTICKERNEL_EXPERIMENTAL_GENAI_ENABLE_OTEL_DIAGNOSTICS=true
SEMANTICKERNEL_EXPERIMENTAL_GENAI_ENABLE_OTEL_DIAGNOSTICS_SENSITIVE=true

# =============================================================================
# Optional: Alternative to Azure Monitor for development
# =============================================================================
LANGFUSE_PUBLIC_KEY= ""
LANGFUSE_SECRET_KEY= ""
LANGFUSE_HOST="https://us.cloud.langfuse.com"
# =============================================================================
# Environment Settings
# =============================================================================
DEPLOYMENT_ENV=development
SK_LOG_LEVEL=INFO

OTEL_PYTHON_DISABLED_INSTRUMENTATIONS=semantic_kernel_function_calling
 